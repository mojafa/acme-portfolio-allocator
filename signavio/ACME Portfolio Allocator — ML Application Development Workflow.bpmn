      </laneSet>
      <startEvent id="Start_Trigger" isInterrupting="true" name="Build / Retrain Trigger">
         <extensionElements>
            <signavio:signavioLabel align="left" ref="text_name" valign="top" x="-28.0" y="37.0"/>
         </extensionElements>
         <outgoing>g1</outgoing>
      </startEvent>
      <task completionQuantity="1" id="Task_IngestMarket" isForCompensation="false" name="Ingest yfinance Prices (12 ETFs)" startQuantity="1">
         <incoming>g1</incoming>
         <incoming>g21</incoming>
         <outgoing>g2</outgoing>
      </task>
      <task completionQuantity="1" id="Task_GenProfiles" isForCompensation="false" name="Generate Synthetic Client Profiles (N=2500)" startQuantity="1">
         <incoming>g2</incoming>
         <outgoing>g3</outgoing>
      </task>
      <task completionQuantity="1" id="Task_LabelFn" isForCompensation="false" name="Apply Adviser Labelling Rule" startQuantity="1">
         <incoming>g3</incoming>
         <outgoing>g4</outgoing>
      </task>
      <task completionQuantity="1" id="Task_FeatureEng" isForCompensation="false" name="Build Feature Matrix (7 client + 3 market)" startQuantity="1">
         <incoming>g4</incoming>
         <outgoing>g5</outgoing>
      </task>
      <task completionQuantity="1" id="Task_Split" isForCompensation="false" name="Train/Test Split + StandardScaler" startQuantity="1">
         <incoming>g5</incoming>
         <outgoing>g6</outgoing>
         <outgoing>g7</outgoing>
         <outgoing>g8</outgoing>
      </task>
      <serviceTask completionQuantity="1" id="Task_TrainDT" implementation="##unspecified" isForCompensation="false" name="Train DecisionTreeClassifier" startQuantity="1">
         <incoming>g6</incoming>
         <outgoing>g9</outgoing>
      </serviceTask>
      <serviceTask completionQuantity="1" id="Task_TrainRF" implementation="##unspecified" isForCompensation="false" name="Train RandomForestClassifier" startQuantity="1">
         <incoming>g7</incoming>
         <incoming>g_metric_no</incoming>
         <outgoing>g10</outgoing>
      </serviceTask>
      <serviceTask completionQuantity="1" id="Task_TrainMLP" implementation="##unspecified" isForCompensation="false" name="Train MLPClassifier" startQuantity="1">
         <incoming>g8</incoming>
         <outgoing>g11</outgoing>
      </serviceTask>
      <task completionQuantity="1" id="Task_Compare" isForCompensation="false" name="Compare Accuracy / F1 / ROC-AUC" startQuantity="1">
         <incoming>g9</incoming>
         <incoming>g10</incoming>
         <incoming>g11</incoming>
         <outgoing>g12</outgoing>
      </task>
      <exclusiveGateway gatewayDirection="Diverging" id="Gw_Metric" name="Meets deployment threshold?">
         <extensionElements>
            <signavio:signavioLabel align="left" ref="text_name" valign="top" x="-30.0" y="-45.0"/>
         </extensionElements>
         <incoming>g12</incoming>
         <outgoing>g_metric_yes</outgoing>
         <outgoing>g_metric_no</outgoing>
      </exclusiveGateway>
      <task completionQuantity="1" id="Task_SelectRF" isForCompensation="false" name="Select Random Forest (best accuracy + explainable)" startQuantity="1">
         <incoming>g_metric_yes</incoming>
         <outgoing>g13</outgoing>
      </task>
      <task completionQuantity="1" id="Task_SHAP" isForCompensation="false" name="Compute SHAP for Transparency" startQuantity="1">
         <incoming>g13</incoming>
         <outgoing>g14</outgoing>
      </task>
      <serviceTask completionQuantity="1" id="Task_JoblibDump" implementation="##unspecified" isForCompensation="false" name="joblib.dump Model + Scaler + Metadata" startQuantity="1">
         <incoming>g14</incoming>
         <outgoing>g15</outgoing>
      </serviceTask>
      <task completionQuantity="1" id="Task_Register" isForCompensation="false" name="Register in Model Registry" startQuantity="1">
         <incoming>g15</incoming>
         <outgoing>g16</outgoing>
      </task>
      <task completionQuantity="1" id="Task_IntegrationTest" isForCompensation="false" name="Integration Test (load + predict new case)" startQuantity="1">
         <incoming>g16</incoming>
         <outgoing>g17</outgoing>
      </task>
      <serviceTask completionQuantity="1" id="Task_ServeStreamlit" implementation="##unspecified" isForCompensation="false" name="Serve via Streamlit Adviser UI" startQuantity="1">
         <incoming>g17</incoming>
         <outgoing>g18</outgoing>
      </serviceTask>
      <serviceTask completionQuantity="1" id="Task_LogPreds" implementation="##unspecified" isForCompensation="false" name="Log Predictions + Probabilities" startQuantity="1">
         <incoming>g18</incoming>
         <incoming>g22</incoming>
         <outgoing>g19</outgoing>
      </serviceTask>
      <serviceTask completionQuantity="1" id="Task_DriftCheck" implementation="##unspecified" isForCompensation="false" name="Check Class-Mix + Confidence Drift" startQuantity="1">
         <incoming>g19</incoming>
         <outgoing>g20</outgoing>
      </serviceTask>
      <exclusiveGateway default="g_drift_no" gatewayDirection="Diverging" id="Gw_Drift" name="Drift detected?">
         <extensionElements>
            <signavio:signavioLabel align="left" ref="text_name" valign="top" x="-20.0" y="-45.0"/>
         </extensionElements>
         <incoming>g20</incoming>
         <outgoing>g_drift_yes</outgoing>
         <outgoing>g_drift_no</outgoing>
      </exclusiveGateway>
      <task completionQuantity="1" id="Task_TriggerRetrain" isForCompensation="false" name="Trigger Retraining" startQuantity="1">
         <incoming>g_drift_yes</incoming>
         <outgoing>g21</outgoing>
      </task>
      <exclusiveGateway default="g_retire_no" gatewayDirection="Diverging" id="Gw_Retire" name="Retire model?">
         <extensionElements>
            <signavio:signavioLabel align="left" ref="text_name" valign="top" x="-20.0" y="50.0"/>
         </extensionElements>
         <incoming>g_drift_no</incoming>
         <outgoing>g_retire_yes</outgoing>
         <outgoing>g_retire_no</outgoing>
      </exclusiveGateway>
      <intermediateCatchEvent id="Timer_Weekly" name="Weekly">
         <extensionElements>
            <signavio:signavioLabel align="left" ref="text_name" valign="top" x="-8.0" y="35.0"/>
         </extensionElements>
         <incoming>g_retire_no</incoming>
         <outgoing>g22</outgoing>
         <timerEventDefinition id="sid-72f1ceda-e0c0-4cd2-a0ec-32265fb78aa1"/>
      </intermediateCatchEvent>
      <endEvent id="End_Retired" name="Model Retired">
         <extensionElements>
            <signavio:signavioLabel align="left" ref="text_name" valign="top" x="-23.0" y="35.0"/>
         </extensionElements>
         <incoming>g_retire_yes</incoming>
      </endEvent>
      <sequenceFlow id="g1" isImmediate="true" sourceRef="Start_Trigger" targetRef="Task_IngestMarket"/>
