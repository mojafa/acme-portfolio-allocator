            <flowNodeRef>Gw_Metric</flowNodeRef>
            <flowNodeRef>Task_SelectRF</flowNodeRef>
            <flowNodeRef>Task_SHAP</flowNodeRef>
         </lane>
         <lane id="Lane_Deployment" name="MLOps / Deployment">
            <flowNodeRef>Task_JoblibDump</flowNodeRef>
            <flowNodeRef>Task_Register</flowNodeRef>
            <flowNodeRef>Task_IntegrationTest</flowNodeRef>
            <flowNodeRef>Task_ServeStreamlit</flowNodeRef>
         </lane>
         <lane id="Lane_Monitoring" name="Monitoring &amp; Retraining">
            <flowNodeRef>Task_LogPreds</flowNodeRef>
            <flowNodeRef>Task_DriftCheck</flowNodeRef>
            <flowNodeRef>Gw_Drift</flowNodeRef>
            <flowNodeRef>Task_TriggerRetrain</flowNodeRef>
            <flowNodeRef>Gw_Retire</flowNodeRef>
            <flowNodeRef>Timer_Weekly</flowNodeRef>
            <flowNodeRef>End_Retired</flowNodeRef>
